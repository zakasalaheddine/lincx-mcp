# ── Required ──────────────────────────────────────────────────────────────────
# Work API base URL — all requests go here, including /api/networks
# networkId is appended as a query param automatically: ?networkId=svce6t
WORK_API_BASE_URL=http://localhost:3050

# ── Optional (defaults shown) ─────────────────────────────────────────────────
# Lincx identity server
IDENTITY_SERVER=https://ix-id.lincx.la

# Port for the Express login UI and health check
PORT=3000

# MCP transport: "stdio" (Claude Code / local IDE) or "http" (remote)
TRANSPORT=stdio

# Redis connection string — leave empty to use in-memory store (dev only)
# In-memory sessions are lost on server restart
REDIS_URL=
